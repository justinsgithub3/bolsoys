<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/styles/upload.css"/>
    <!-- partials -->
    <link rel="stylesheet" href="/styles/partials/header.css"/>
    <link rel="stylesheet" href="/styles/partials/footer.css"/>

    <title>Bolsoy's | upload</title>
</head>
<body>
    <%- include ("./partials/header.ejs") %>

    <div class="main-content">
        <form class="post-form" method="POST" enctype="multipart/form-data" action="/api/drawings">
            <label for="form-drawing" class="camera-label">
            <span id="button-text">Open Files</span>
            <input class="camera" id="form-drawing" type="file" name="form-drawing" 
                    accept="image/*" style="display: none;"/>
                <!-- removed  capture="user"  -->
            </label>
        </form>
        <p>scan your drawing on a computer and upload it to the gallery!</p>
    </div>

    <%- include ("./partials/footer.ejs") %>

    <script type="module" src="/assets/js/uploadJs.js"></script>
</body>
</html>